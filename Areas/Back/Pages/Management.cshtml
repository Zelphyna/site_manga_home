@page
@model site_manga_home.Areas.Back.Pages.ManagementModel
@{
    ViewData["Title"] = "Gestion des mangas";
}

<div class="pt-3 mb-4">
    <a class="text-muted text-decoration-none" asp-area="Front" asp-page="/Index">&larr; Retour à la collection</a>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3">Mangas</h1>
    <a class="btn btn-primary" asp-area="Back" asp-page="/Mangas/Edit">+ Ajouter un manga</a>
</div>

@if (Model.Mangas.Count == 0)
{
    <div class="alert alert-info">
        Aucun manga actuellement.
        <a asp-area="Back" asp-page="/Mangas/Edit">Ajouter le premier manga</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Titre</th>
                    <th>Couverture</th>
                    <th>Tomes total</th>
                    <th>Tomes possédés</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var manga in Model.Mangas)
                {
                    <tr>
                        <td class="align-middle">@manga.Titre</td>
                        <td class="align-middle">
                            @if (!string.IsNullOrEmpty(manga.CoverUrl))
                            {
                                <img src="@manga.CoverUrl" alt="@manga.Titre" style="max-height: 60px;" />
                            }
                        </td>
                        <td class="align-middle">@(manga.TomesTotal > 0 ? manga.TomesTotal.ToString() : "—")</td>
                        <td class="align-middle">@(manga.TomesPossedes > 0 ? manga.TomesPossedes.ToString() : "—")</td>
                        <td class="align-middle text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-area="Back" asp-page="/Mangas/Edit" asp-route-id="@manga.Id">Modifier</a>
                            <form method="post" asp-page-handler="delete" asp-route-id="@manga.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Êtes-vous sûr ?')">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
