@page
@model site_manga_home.Areas.Back.Pages.IndexModel
@{
    ViewData["Title"] = "Gestion des Mangas";
}

<div class="d-flex justify-content-between align-items-center mb-4 pt-3">
    <h1 class="h2 fw-bold">Gestion des Mangas</h1>
    <a class="btn btn-primary" asp-area="Back" asp-page="/Mangas/Edit">+ Ajouter un manga</a>
</div>

@if (!Model.Mangas.Any())
{
    <div class="text-center py-5 text-muted">
        <p class="fs-5">Aucun manga enregistré.</p>
    </div>
}
else
{
    @Html.AntiForgeryToken()
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width:60px">Cover</th>
                    <th>Titre</th>
                    <th class="text-center">Tomes possédés</th>
                    <th class="text-center">Total</th>
                    <th class="text-center" style="width:160px">Progression</th>
                    <th class="text-end" style="width:160px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var manga in Model.Mangas)
                {
                    var pct = manga.TomesTotal > 0 ? manga.TomesPossedes * 100 / manga.TomesTotal : 0;
                    <tr>
                        <td>
                            <img src="@manga.CoverUrl" alt="@manga.Titre" class="manga-thumb" />
                        </td>
                        <td class="fw-semibold">@manga.Titre</td>
                        <td class="text-center">
                            <div class="tomes-counter">
                                <button class="btn btn-sm btn-outline-secondary"
                                        hx-post="?handler=Decrement&id=@manga.Id"
                                        hx-target="#tomes-@manga.Id"
                                        hx-swap="innerHTML">−</button>
                                <span id="tomes-@manga.Id" class="fw-bold">@manga.TomesPossedes</span>
                                <button class="btn btn-sm btn-outline-secondary"
                                        hx-post="?handler=Increment&id=@manga.Id"
                                        hx-target="#tomes-@manga.Id"
                                        hx-swap="innerHTML">+</button>
                            </div>
                        </td>
                        <td class="text-center text-muted">@manga.TomesTotal</td>
                        <td class="text-center">
                            <div class="progress mb-1" style="height:6px">
                                <div class="progress-bar bg-success" style="width:@pct%"></div>
                            </div>
                            <small class="text-muted">@pct%</small>
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary me-1"
                               asp-area="Back" asp-page="/Mangas/Edit" asp-route-id="@manga.Id">Modifier</a>
                            <form method="post" class="d-inline">
                                <button type="submit"
                                        asp-page-handler="Delete"
                                        asp-route-id="@manga.Id"
                                        class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Supprimer @Html.Raw(manga.Titre.Replace("'", "\\'")) ?')">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>
        document.body.addEventListener('htmx:configRequest', (e) => {
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) e.detail.headers['RequestVerificationToken'] = token.value;
        });
    </script>
}
